{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "firstmate-activation-request@1",
  "title": "Firstmate activation request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "activationId", "repository", "objective",
    "expectedNetValue", "ownerSurface", "proofGate", "stopRule", "rollback",
    "budget", "expiresAt", "sourceEvidenceRefs", "requestedTrustStage",
    "policyHash", "requestHash"
  ],
  "properties": {
    "schemaVersion": {"const": "firstmate-activation-request@1"},
    "activationId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,79}$"},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "objective": {"type": "string", "minLength": 1, "maxLength": 500},
    "expectedNetValue": {
      "type": "object", "additionalProperties": false,
      "required": ["amountUsd", "components", "confidence"],
      "properties": {
        "amountUsd": {"type": "number"},
        "components": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "ownerSurface": {"type": "string", "minLength": 1},
    "proofGate": {"type": "string", "minLength": 1},
    "stopRule": {"type": "string", "minLength": 1},
    "rollback": {"type": "string", "minLength": 1},
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": ["maxUsd", "maxMinutes", "maxFiles", "maxConcurrency"],
      "properties": {
        "maxUsd": {"type": "number", "minimum": 0},
        "maxMinutes": {"type": "integer", "minimum": 1},
        "maxFiles": {"type": "integer", "minimum": 1},
        "maxConcurrency": {"type": "integer", "minimum": 1}
      }
    },
    "expiresAt": {"type": "string", "format": "date-time"},
    "sourceEvidenceRefs": {"type": "array", "items": {"type": "string", "pattern": "^[A-Za-z0-9._:/@+-]+$"}},
    "requestedTrustStage": {"type": "string", "minLength": 1},
    "policyHash": {"type": "string", "minLength": 1},
    "requestHash": {"type": "string", "minLength": 1}
  }
}
